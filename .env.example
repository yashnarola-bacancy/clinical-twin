# ─────────────────────────────────────────────────────────────
# Clinical Twin — environment variables
# Copy this file to ".env" and fill in the values:
#     cp .env.example .env        (macOS/Linux)
#     copy .env.example .env      (Windows CMD)
#     Copy-Item .env.example .env (Windows PowerShell)
# ─────────────────────────────────────────────────────────────

# Database (REQUIRED) — PostgreSQL connection string.
# The demo uses Neon (https://neon.tech). Any PostgreSQL 14+ instance works.
DATABASE_URL=""

# Mock AI mode (RECOMMENDED for local dev / demo).
# "true"  -> no API keys needed; transcription + SOAP note are canned responses.
# "false" -> uses the real Whisper + Claude calls (requires the keys below).
MOCK_AI="true"

# AI providers — only required when MOCK_AI is NOT "true".
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# App secret — any random string (e.g. `openssl rand -base64 32`).
# Auth.js v5 reads AUTH_SECRET; NEXTAUTH_SECRET is kept as a fallback.
AUTH_SECRET=""
NEXTAUTH_SECRET=""
